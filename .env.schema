# Edge cache lifetime for normalized feeds.
# @sensitive=false @type=number
FEED_CACHE_TTL_SECONDS=300

# Maximum upstream feed or discovery response size.
# @sensitive=false @type=number
FEED_MAX_RESPONSE_BYTES=2097152
